{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GROVE-AI Opportunity",
  "type": "object",
  "required": [
    "opportunity_id",
    "opportunity_statement",
    "importance",
    "dissatisfaction",
    "frequency",
    "evidence_confidence",
    "strategic_fit",
    "technical_risk",
    "business_risk",
    "evidence_ids"
  ],
  "properties": {
    "opportunity_id": {
      "type": "string",
      "pattern": "^O-[A-Za-z0-9_-]+$"
    },
    "job_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "opportunity_statement": {
      "type": "string",
      "minLength": 1
    },
    "importance": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "dissatisfaction": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "frequency": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "evidence_confidence": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "strategic_fit": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "technical_risk": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "business_risk": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "counter_evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "raw_score": {
      "type": [
        "number",
        "null"
      ]
    },
    "normalized_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    }
  },
  "additionalProperties": true
}