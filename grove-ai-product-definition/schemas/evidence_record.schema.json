{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GROVE-AI Evidence Record",
  "type": "object",
  "required": [
    "evidence_id",
    "claim_id",
    "source_type",
    "summary",
    "statement_type",
    "confidence_1_5",
    "historical_eligible"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^E-[A-Za-z0-9_-]+$"
    },
    "claim_id": {
      "type": "string",
      "pattern": "^C-[A-Za-z0-9_-]+$"
    },
    "product_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "market": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_type": {
      "type": "string",
      "enum": [
        "standard",
        "regulator",
        "official",
        "manual",
        "recall",
        "independent_review",
        "retailer_review",
        "community",
        "news",
        "academic",
        "synthetic_user",
        "internal"
      ]
    },
    "url": {
      "type": [
        "string",
        "null"
      ]
    },
    "date_published": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "date_accessed": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "statement_type": {
      "type": "string",
      "enum": [
        "FACT",
        "INFERENCE",
        "HYPOTHESIS"
      ]
    },
    "polarity": {
      "type": "string",
      "enum": [
        "support",
        "counter",
        "neutral"
      ]
    },
    "pain_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "job_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_quality_1_5": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "confidence_1_5": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "duplicate_cluster": {
      "type": [
        "string",
        "null"
      ]
    },
    "historical_eligible": {
      "type": "boolean"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}